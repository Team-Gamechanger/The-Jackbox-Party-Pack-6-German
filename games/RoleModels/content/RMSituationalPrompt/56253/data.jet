{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt0"},{"t":"B","v":"false","n":"HasRevealPrompt1"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt5"},{"t":"B","v":"false","n":"HasRevealPrompt6"},{"t":"B","v":"false","n":"HasRevealPrompt7"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"A","s":"Wo würdest du eine Leiche verstecken?","n":"RevealPrompt0"},{"t":"A","s":"Wie heißen deine geheimen Kinder?","n":"RevealPrompt1"},{"t":"A","s":"Wer hat gerade wahrscheinlich am meisten Bargeld dabei?","n":"RevealPrompt4"},{"t":"A","s":"Was war das Ekligste, das du je gegessen hast?","n":"RevealPrompt5"},{"t":"A","s":"Wer hasst den Raum und wer glaubt nur, dass der Raum ihn hasst?","n":"RevealPrompt6"},{"t":"A","s":"Wie lautet dein geheimes Codewort, mit dem du anderen Aliens zeigst, dass du auch eins bist?","n":"RevealPrompt7"},{"t":"A","s":"Wenn es nur eine ist, ist es halb so wild.","v":"joke0","n":"RevealJoke0"},{"t":"A","s":"Ich gebe den Buchhaltern die Schuld.","v":"joke4","n":"RevealJoke1"},{"t":"A","s":"Ich weiß, du hast viele Mäuler zu stopfen. Schon mal Knabberpunkte probiert?","v":"joke1","n":"RevealJoke2"},{"t":"A","s":"Deine Augen haben dich verraten.","v":"joke7","n":"RevealJoke3"},{"t":"A","s":"Eigentlich soll ich neutral bleiben, aber du bist ein widerlicher Mensch.","v":"joke5","n":"RevealJoke4"},{"t":"A","s":"Was für ein Moment, das herauszufinden, was?","v":"joke6","n":"RevealJoke5"},{"t":"A","s":"Was sind eure wahrscheinlich dunkelsten Geheimnisse?","v":"prompt","n":"Prompt"}]}
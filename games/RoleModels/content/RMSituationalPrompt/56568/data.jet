{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt5"},{"t":"B","v":"false","n":"HasRevealPrompt6"},{"t":"B","v":"false","n":"HasRevealPrompt7"},{"t":"B","v":"false","n":"HasRevealPrompt8"},{"t":"B","v":"false","n":"HasRevealPrompt9"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"false","n":"HasRevealJoke2"},{"t":"B","v":"false","n":"HasRevealJoke3"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"A","s":"Warum bist du als Mitglied der ersten Klasse besser als alle anderen hier?","n":"RevealPrompt4"},{"t":"A","s":"Was bringt dich immer zum Weinen?","n":"RevealPrompt5"},{"t":"A","s":"Mit welcher Taktik würdest du dich an Bord schleichen?","n":"RevealPrompt6"},{"t":"A","s":"Was ist eine Sache, bei der du dich geirrt hast und von der du trotzdem nicht zurückweichen wolltest?","n":"RevealPrompt7"},{"t":"A","s":"Was machst du mit dem Piloten, wenn er sich weigert, deinen Befehlen zu gehorchen?","n":"RevealPrompt8"},{"t":"A","s":"Beschreibe mit deiner besten Kapitänsstimme, was jeder sehen kann, wenn er aus dem Fenster schaut.","n":"RevealPrompt9"},{"t":"A","s":"Mit dir als Pilot fühle ich mich richtig gut aufgehoben.","v":"joke9","n":"RevealJoke0"},{"t":"A","s":"Wohin geht dann die Reise genau, wenn man mal fragen darf?","v":"joke8","n":"RevealJoke1"},{"t":"A","s":"","n":"RevealJoke2"},{"t":"A","s":"","n":"RevealJoke3"},{"t":"A","s":"Da könnte ich auch nicht die Tränen zurückhalten.","v":"joke5","n":"RevealJoke4"},{"t":"A","s":"Die Lufthansa würde gerne mit dir ein paar Wörtchen reden.","v":"joke6","n":"RevealJoke5"},{"t":"A","s":"Wer seid ihr in diesem Flugzeug?","v":"prompt","n":"Prompt"}]}
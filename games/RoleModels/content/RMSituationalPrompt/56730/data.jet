{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt0"},{"t":"B","v":"false","n":"HasRevealPrompt1"},{"t":"B","v":"false","n":"HasRevealPrompt2"},{"t":"B","v":"false","n":"HasRevealPrompt3"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt7"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"A","s":"Was ist die passivste Art zu sterben, die man vielleicht gar nicht bemerkt?","n":"RevealPrompt0"},{"t":"A","s":"Beschreibe dein ideales Leben nach dem Tod.","n":"RevealPrompt1"},{"t":"A","s":"Wenn du wählen müsstest, welche berühmte Person würdest du am liebsten essen?","n":"RevealPrompt2"},{"t":"A","s":"Spiele die Szene nach, in der du erkennst, dass diese außerirdische Höllenlandschaft eigentlich die Erde ist.","n":"RevealPrompt3"},{"t":"A","s":"Wer hat überraschend gute Ideen?","n":"RevealPrompt4"},{"t":"A","s":"Wer ist dein prominenter Zwilling?","n":"RevealPrompt7"},{"t":"A","s":"Ich hatte die ganze Zeit schon ein komisches Gefühl dabei.","v":"joke0","n":"RevealJoke0"},{"t":"A","s":"Guten Morgen, schon wach?","v":"joke1","n":"RevealJoke1"},{"t":"A","s":"Können Sie mir das einpacken?","v":"joke2","n":"RevealJoke2"},{"t":"A","s":"Trautes Heim, Glück allein.","v":"joke3","n":"RevealJoke3"},{"t":"A","s":"Sei schlau, stell dich dumm.","v":"joke4","n":"RevealJoke4"},{"t":"A","s":"Habe ich dich nicht schonmal woanders gesehen?","v":"joke7","n":"RevealJoke5"},{"t":"A","s":"Welches überraschende Ende seid ihr?","v":"prompt","n":"Prompt"}]}
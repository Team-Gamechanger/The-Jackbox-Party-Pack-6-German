{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt1"},{"t":"B","v":"false","n":"HasRevealPrompt2"},{"t":"B","v":"false","n":"HasRevealPrompt3"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt5"},{"t":"B","v":"false","n":"HasRevealPrompt6"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"false","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"A","s":"Was war die absurdeste Art, wie du je Geld sparen wolltest?","n":"RevealPrompt1"},{"t":"A","s":"Mit welchem Spieler würdest du dich unter eine Decke vor ein warmes Feuer kuscheln... während du furchtbaren Durchfall hast?","n":"RevealPrompt2"},{"t":"A","s":"Welches Buch und warum?","n":"RevealPrompt3"},{"t":"A","s":"Was war der schlimmste Ort, an dem du dich je erleichtern musstest?","n":"RevealPrompt4"},{"t":"A","s":"Beschreibe Stil und Muster deiner Notfallsocke.","n":"RevealPrompt5"},{"t":"A","s":"Wer wischt nicht, weil er ausschließlich ein Bidet benutzt, und wer... wischt einfach gar nicht?","n":"RevealPrompt6"},{"t":"A","s":"Die erste Wahl eleganter Omas.","v":"joke2","n":"RevealJoke0"},{"t":"A","s":"Du Geizhals.","v":"joke1","n":"RevealJoke1"},{"t":"A","s":"Ah, das Wischen der Intellektuellen.","v":"joke3","n":"RevealJoke2"},{"t":"A","s":"Kein Kommentar.","v":"joke5","n":"RevealJoke3"},{"t":"A","s":"","n":"RevealJoke4"},{"t":"A","s":"Igitt.","v":"joke6","n":"RevealJoke5"},{"t":"A","s":"Seid ehrlich: Welches Material zum Hinternabwischen seid ihr?","v":"prompt","n":"Prompt"}]}
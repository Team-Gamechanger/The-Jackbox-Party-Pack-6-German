{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"B","v":"true","n":"HasRevealPrompt0"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealPrompt1"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"false","n":"HasRevealPrompt2"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"true","n":"HasRevealPrompt3"},{"t":"B","v":"true","n":"HasRevealPrompt4"},{"t":"B","v":"true","n":"HasRevealPrompt5"},{"t":"B","v":"true","n":"HasRevealPrompt6"},{"s":"Freunde, Donnerstag ist bekanntlich Dönerstag!","t":"A","v":"joke5","n":"RevealJoke5"},{"s":"Es ist Mittwoch, meine Kerle!","t":"A","v":"joke4","n":"RevealJoke4"},{"s":"","t":"A","n":"RevealPrompt2"},{"s":"Wer feiert am Freitag eher um 18.00 Uhr?","t":"A","v":"revealprompt1","n":"RevealPrompt1"},{"s":"Was macht den Mittwoch besonders?","t":"A","v":"revealprompt4","n":"RevealPrompt4"},{"s":"Du hast 24 Stunden ganz für dich allein, was wirst du damit machen?","t":"A","v":"revealprompt3","n":"RevealPrompt3"},{"s":"Klingt auf jeden Fall sehr entspannend.","t":"A","v":"joke3","n":"RevealJoke3"},{"s":"Wer hat keine Schwierigkeiten, am Sonntag bis mittags zu schlafen?","t":"A","v":"revealprompt6","n":"RevealPrompt6"},{"s":"Ich hasse Montage...","t":"A","v":"joke7","n":"RevealJoke2"},{"s":"Warum ist der Donnerstag eigentlich besser als der Freitag?","t":"A","v":"revealprompt5","n":"RevealPrompt5"},{"s":"Manchmal muss man sich auch etwas Schlaf gönnen.","t":"A","v":"joke6","n":"RevealJoke1"},{"s":"8 Stunden nichts geschafft. Jetzt endlich Feierabend! Juhu!","t":"A","v":"joke1","n":"RevealJoke0"},{"s":"Was ist dein erster Gedanke an einem Montagmorgen?","t":"A","v":"revealprompt0","n":"RevealPrompt0"},{"s":"Welcher Wochentag repräsentiert jeden von euch am besten?","t":"A","v":"prompt","n":"Prompt"}]}
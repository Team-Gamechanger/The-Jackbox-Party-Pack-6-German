{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt0"},{"t":"B","v":"false","n":"HasRevealPrompt2"},{"t":"B","v":"false","n":"HasRevealPrompt6"},{"t":"B","v":"false","n":"HasRevealPrompt7"},{"t":"B","v":"false","n":"HasRevealPrompt8"},{"t":"B","v":"false","n":"HasRevealPrompt9"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"A","s":"Du findest das richtige Centstück nicht und die Leute werden immer ungeduldiger. Was machst du?","n":"RevealPrompt0"},{"t":"A","s":"Eins deiner Kinder läuft zum Ausgang, während du bezahlst. Worum kümmerst du dich zuerst?","n":"RevealPrompt2"},{"t":"A","s":"Eine Dame möchte einen Artikel umtauschen, hat aber den Bon verloren. Wie reagierst du?","n":"RevealPrompt6"},{"t":"A","s":"Du versuchst ein 10-Liter-Bierfass zu klauen. Wie stellst du das an?","n":"RevealPrompt7"},{"t":"A","s":"Hinter dir steht ein 2-Meter-Hüne, der dich grimmig anschaut und ein Rollstuhlfahrer, die beide vor wollen. Was tust du?","n":"RevealPrompt8"},{"t":"A","s":"Was sagst du, wenn du nach deinem Ausweis gefragt wirst?","n":"RevealPrompt9"},{"t":"A","s":"Für dich macht man eine weitere Kasse auf.","v":"joke0","n":"RevealJoke0"},{"t":"A","s":"Danke, meine Migräne hat mir jetzt noch gefehlt.","v":"joke2","n":"RevealJoke1"},{"t":"A","s":"(genervt) Bar oder mit Karte?","v":"joke6","n":"RevealJoke2"},{"t":"A","s":"Du sammelst Hausverbote, als wären es Payback-Punkte.","v":"joke7","n":"RevealJoke3"},{"t":"A","s":"Du bist zu nett für diese Welt.","v":"joke8","n":"RevealJoke4"},{"t":"A","s":"Ja, das kann ich mir bei dir vorstellen.","v":"joke9","n":"RevealJoke5"},{"t":"A","s":"Welche Art von Person an einer Supermarktkasse seid ihr?","v":"prompt","n":"Prompt"}]}
{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt0"},{"t":"B","v":"false","n":"HasRevealPrompt1"},{"t":"B","v":"false","n":"HasRevealPrompt2"},{"t":"B","v":"false","n":"HasRevealPrompt3"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt5"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"A","s":"Du heiratest Chris Tall. Wie lautet euer Hochzeits-Hashtag?","n":"RevealPrompt0"},{"t":"A","s":"Wonach riecht der Atem von jemandem, nachdem er dich gekaut hat?","n":"RevealPrompt1"},{"t":"A","s":"Jemand legt dich in seine Kramschublade. Mit welchem anderen nutzlosen Gegenstand freundest du dich an?","n":"RevealPrompt2"},{"t":"A","s":"Welcher Rezensionsspruch stünde auf deiner Rückseite?","n":"RevealPrompt3"},{"t":"A","s":"Was war das Beste, das du je in unter fünf Stunden geschafft hast?","n":"RevealPrompt4"},{"t":"A","s":"Du wirst geschrumpft und in den Kampf gegen eine Armee von Grippeviren geschickt. Welche Waffe wählst du?","n":"RevealPrompt5"},{"t":"A","s":"Dir steht es am besten!","v":"joke0","n":"RevealJoke0"},{"t":"A","s":"Frisch.","v":"joke1","n":"RevealJoke1"},{"t":"A","s":"Katsching.","v":"joke2","n":"RevealJoke2"},{"t":"A","s":"In Elyas M'Bareks Augenbrauen könnte ich einschlafen.","v":"joke3","n":"RevealJoke3"},{"t":"A","s":"Immer noch wach?","v":"joke4","n":"RevealJoke4"},{"t":"A","s":"So gut vorbereitet.","v":"joke5","n":"RevealJoke5"},{"t":"A","s":"Welcher überteuerte Impulskauf seid ihr?","v":"prompt","n":"Prompt"}]}
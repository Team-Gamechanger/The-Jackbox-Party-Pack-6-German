{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"B","v":"false","n":"HasRevealPrompt0"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"false","n":"HasRevealPrompt1"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"false","n":"HasRevealPrompt2"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"false","n":"HasRevealPrompt7"},{"t":"B","v":"false","n":"HasRevealPrompt8"},{"t":"B","v":"false","n":"HasRevealPrompt3"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt5"},{"s":"So gut vorbereitet.","t":"A","v":"831059_1","n":"RevealJoke5"},{"s":"Immer noch wach?","t":"A","v":"831058_1","n":"RevealJoke4"},{"s":"Jemand legt dich in seine Kramschublade. Mit welchem anderen nutzlosen Gegenstand freundest du dich an?","t":"A","n":"RevealPrompt2"},{"s":"Wonach riecht der Atem von jemandem, nachdem er dich gekaut hat?","t":"A","n":"RevealPrompt1"},{"s":"Was war das Beste, das du je in unter fünf Stunden geschafft hast?","t":"A","n":"RevealPrompt4"},{"s":"Welcher Rezensionsspruch stünde auf deiner Rückseite?","t":"A","n":"RevealPrompt3"},{"s":"In Peter Gallaghers Augenbrauen könnte ich einschlafen.","t":"A","v":"831057_1","n":"RevealJoke3"},{"s":"Katsching.","t":"A","v":"831056_1","n":"RevealJoke2"},{"s":"Du wirst geschrumpft und in den Kampf gegen eine Armee von Grippeviren geschickt. Welche Waffe wählst du?","t":"A","n":"RevealPrompt5"},{"s":"Frisch.","t":"A","v":"831055_1","n":"RevealJoke1"},{"s":"","t":"A","n":"RevealPrompt8"},{"s":"Dir steht es am besten!","t":"A","v":"831054_1","n":"RevealJoke0"},{"s":"Wen würdest du als “belebende Sammlung mysteriöser Zutaten” beschreiben?","t":"A","n":"RevealPrompt7"},{"s":"Du heiratest Chris Tall. Wie lautet euer Hochzeits-Hashtag?","t":"A","n":"RevealPrompt0"},{"s":"Welcher überteuerte Impulskauf seid ihr?","t":"A","v":"831047_1","n":"Prompt"}]}
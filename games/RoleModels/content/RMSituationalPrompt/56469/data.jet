{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt0"},{"t":"B","v":"false","n":"HasRevealPrompt1"},{"t":"B","v":"false","n":"HasRevealPrompt3"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt5"},{"t":"B","v":"false","n":"HasRevealPrompt6"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"false","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"A","s":"Wer würde am ehesten im Gefängnis landen?","n":"RevealPrompt0"},{"t":"A","s":"Was macht dich glücklich?","n":"RevealPrompt1"},{"t":"A","s":"Was ist die chaotischste Sache, die du in letzter Zeit getan hast?","n":"RevealPrompt3"},{"t":"A","s":"Was ist etwas, das du gut kannst?","n":"RevealPrompt4"},{"t":"A","s":"Auf wen trifft der Satz „Harte Schale, weicher Kern” am ehesten zu?","n":"RevealPrompt5"},{"t":"A","s":"Wer ist am sensibelsten?","n":"RevealPrompt6"},{"t":"A","s":"Guten Morgen, Sonnenschein!","v":"joke1","n":"RevealJoke0"},{"t":"A","s":"Nur die Harten kommen in den Garten.","v":"joke0","n":"RevealJoke1"},{"t":"A","s":"Rühr dich bloß nicht vom Fleck.","v":"joke3","n":"RevealJoke2"},{"t":"A","s":"Du hast den Dreh raus!","v":"joke4","n":"RevealJoke3"},{"t":"A","s":"","n":"RevealJoke4"},{"t":"A","s":"Du brichst schon zusammen bei leichtem Druck. Wie ein Ei.","v":"joke6","n":"RevealJoke5"},{"t":"A","s":"Welche Zubereitungsart von Ei spiegelt euch am besten wider?","v":"prompt","n":"Prompt"}]}
{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt1"},{"t":"B","v":"false","n":"HasRevealPrompt2"},{"t":"B","v":"false","n":"HasRevealPrompt3"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt5"},{"t":"B","v":"false","n":"HasRevealPrompt7"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"false","n":"HasRevealJoke5"},{"t":"A","s":"Demonstriere den grinsenden Todesblick des gruseligen Kindes aus <i>Das Omen</i>.","n":"RevealPrompt1"},{"t":"A","s":"Wie viel Geld bräuchtest du, um einen unschuldigen Sündenbock ins Gefängnis zu schicken?","n":"RevealPrompt2"},{"t":"A","s":"Wenn du Anhalter wärst, was stünde auf deinem Schild?","n":"RevealPrompt3"},{"t":"A","s":"Vor wem hättest du am meisten Angst, wenn er in voller Clown-Montur vor deiner Tür stünde?","n":"RevealPrompt4"},{"t":"A","s":"Antworte als rothäutiges Biest mit Hörnern: Wie sieht dein Traumhaus aus?","n":"RevealPrompt5"},{"t":"A","s":"Mit welchem Spruch sprichst du einen einsamen Fremden an, um seine Seele zu stehlen?","n":"RevealPrompt7"},{"t":"A","s":"“Freiheit, Baby, bedeutet, nie sagen zu müssen, dass es dir leidtut.”","v":"joke2","n":"RevealJoke0"},{"t":"A","s":"Du heißer Teufel.","v":"joke7","n":"RevealJoke1"},{"t":"A","s":"Lauf schön zu Mami.","v":"joke1","n":"RevealJoke2"},{"t":"A","s":"Deshalb hasse ich den Zirkus.","v":"joke4","n":"RevealJoke3"},{"t":"A","s":"Das ist ein mörderisches Halloween-Kostüm.","v":"joke5","n":"RevealJoke4"},{"t":"A","s":"","n":"RevealJoke5"},{"t":"A","s":"Welche Art Filmteufel seid ihr?","v":"prompt","n":"Prompt"}]}
{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt0"},{"t":"B","v":"false","n":"HasRevealPrompt1"},{"t":"B","v":"false","n":"HasRevealPrompt2"},{"t":"B","v":"false","n":"HasRevealPrompt3"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt5"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"false","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"A","s":"Welchen Duft hast du?","n":"RevealPrompt0"},{"t":"A","s":"Welcher Spieler würde am ehesten ein Heiliger werden?","n":"RevealPrompt1"},{"t":"A","s":"Was ist in deinem Portemonnaie, das du im letzten Jahr nicht einmal angeschaut hast?","n":"RevealPrompt2"},{"t":"A","s":"Mit wem würdest du lieber zum Abschlussball gehen?","n":"RevealPrompt3"},{"t":"A","s":"Was war der letzte Traum, den du dir bei einer Mitfahrgelegenheit eingefangen hast?","n":"RevealPrompt4"},{"t":"A","s":"Was ist deine Glückszahl?","n":"RevealPrompt5"},{"t":"A","s":"Ganz ehrlich, wie lange hängst du da schon und wie lange riechst du nach nichts mehr?","v":"joke0","n":"RevealJoke0"},{"t":"A","s":"Das wird noch ins Auge gehen.","v":"joke1","n":"RevealJoke1"},{"t":"A","s":"","n":"RevealJoke2"},{"t":"A","s":"Du jagst diesem Abend immer noch hinterher, oder?","v":"joke3","n":"RevealJoke3"},{"t":"A","s":"Ich muss aufpassen, nicht in dich reinzugeraten.","v":"joke4","n":"RevealJoke4"},{"t":"A","s":"Warte, aus WELCHEM Jahr bist du?","v":"joke2","n":"RevealJoke5"},{"t":"A","s":"Welches am Rückspiegel hängende Accessoire seid ihr?","v":"prompt","n":"Prompt"}]}
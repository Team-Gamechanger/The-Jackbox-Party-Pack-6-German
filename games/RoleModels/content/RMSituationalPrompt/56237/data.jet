{"fields":[{"t":"B","v":"true","n":"HasPrompt"},{"t":"B","v":"false","n":"HasRevealPrompt1"},{"t":"B","v":"false","n":"HasRevealPrompt2"},{"t":"B","v":"false","n":"HasRevealPrompt4"},{"t":"B","v":"false","n":"HasRevealPrompt5"},{"t":"B","v":"false","n":"HasRevealPrompt7"},{"t":"B","v":"false","n":"HasRevealPrompt10"},{"t":"B","v":"true","n":"HasRevealJoke0"},{"t":"B","v":"true","n":"HasRevealJoke1"},{"t":"B","v":"true","n":"HasRevealJoke2"},{"t":"B","v":"true","n":"HasRevealJoke3"},{"t":"B","v":"true","n":"HasRevealJoke4"},{"t":"B","v":"true","n":"HasRevealJoke5"},{"t":"A","s":"Wer ist am nachtaktivsten?","n":"RevealPrompt1"},{"t":"A","s":"Wer beraubt Fort Knox wegen des Goldes und wer beraubt es wegen des Nervenkitzels?","n":"RevealPrompt2"},{"t":"A","s":"Wer bringt Leute dazu, sich zu streiten, nur weil er das Drama liebt?","n":"RevealPrompt4"},{"t":"A","s":"Was ist ein guter Spitzname für einen Schurken mit Wasserthema?","n":"RevealPrompt5"},{"t":"A","s":"Wer hat wohl ein Buch mit Denksportaufgaben in seinem Bücherregal?","n":"RevealPrompt7"},{"t":"A","s":"Starre jemanden im Raum an, als ob du in seine Seele sehen könntest.","n":"RevealPrompt10"},{"t":"A","s":"Du standest schon immer im Schatten der anderen, oder?","v":"joke1","n":"RevealJoke0"},{"t":"A","s":"Viel Glück damit.","v":"joke2","n":"RevealJoke1"},{"t":"A","s":"Schonmal mit Kreuzworträtseln versucht?","v":"joke7","n":"RevealJoke2"},{"t":"A","s":"Du willst nicht wissen, was in meinem Kopf vorgeht.","v":"joke10","n":"RevealJoke3"},{"t":"A","s":"Hast du nichts Besseres zu tun?","v":"joke4","n":"RevealJoke4"},{"t":"A","s":"Sehr tierlieb von dir.","v":"joke5","n":"RevealJoke5"},{"t":"A","s":"Welchen Superschurkenplan würde jeder von euch verwenden?","v":"prompt","n":"Prompt"}]}